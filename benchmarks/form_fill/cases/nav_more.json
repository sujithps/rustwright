[
  {
    "id": "internet_tables_read_sorted_last_names",
    "category": "navigation",
    "url": "https://the-internet.herokuapp.com/tables",
    "nav_steps": [
      {
        "op": "goto",
        "url": "https://the-internet.herokuapp.com/tables"
      },
      {
        "op": "wait",
        "selector": "#table1 tbody tr"
      },
      {
        "op": "eval",
        "expression": "Array.from(document.querySelectorAll('#table1 tbody .last-name'), (cell) => cell.textContent.trim()).sort((left, right) => left.localeCompare(right))"
      }
    ]
  },
